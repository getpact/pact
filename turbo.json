{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URL",
        "RLS_TEST_DB",
        "MEK",
        "ENVIRONMENT",
        "ISSUER_BASE_URL",
        "ADMIN_AUDIENCE",
        "AUDIT_AUDIENCE",
        "MCP_AUDIENCE",
        "GATEWAY_AUDIENCE",
        "PG_POOL_MAX",
        "PG_IDLE_TIMEOUT",
        "LOG_LEVEL",
        "PACT_QUIET_PG_NOTICES"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
