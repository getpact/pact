{
  "name": "@getpact/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "bin": {
    "pact": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@getpact/audit": "workspace:*",
    "@getpact/crypto": "workspace:*",
    "@getpact/db": "workspace:*"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "README.md",
    "LICENSE"
  ]
}
