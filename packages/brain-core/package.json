{
  "name": "@getpact/brain-core",
  "version": "0.0.0",
  "description": "Audience-aware search primitives used internally by Pact. Fork of gbrain.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./search": {
      "types": "./src/search/index.ts",
      "import": "./src/search/index.ts"
    },
    "./chunkers": {
      "types": "./src/chunkers/index.ts",
      "import": "./src/chunkers/index.ts"
    },
    "./embedding": {
      "types": "./src/embedding/index.ts",
      "import": "./src/embedding/index.ts"
    }
  },
  "files": [
    "src",
    "LICENSE",
    "LICENSE-UPSTREAM",
    "UPSTREAM.md",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
