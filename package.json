{
  "name": "pact",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.2",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:db": "bash scripts/test-db.sh",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "check:cloudflare": "node scripts/validate-cloudflare-config.mjs issuer verifier mcp-server admin-api audit-api",
    "check:cloudflare:gateway": "node scripts/validate-cloudflare-config.mjs issuer verifier mcp-server admin-api audit-api gateway",
    "check:openapi": "node scripts/check-openapi.mjs",
    "deploy:cloudflare": "sh scripts/deploy-cloudflare.sh",
    "smoke:cloudflare": "node scripts/smoke-cloudflare.mjs",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.0.0",
    "lefthook": "^1.7.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
