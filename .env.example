# Copy to .env and source before running tests: `set -a; . ./.env; set +a`
# Or use: `pnpm test:db` to run tests with these defaults loaded.

DATABASE_URL=postgres://pact:pact@localhost:5432/pact
RLS_TEST_DB=postgres://pact_app:pact_app@localhost:5432/pact

# Test pool size kept small to stay under Postgres max_connections.
PG_POOL_MAX=4

# Cloudflare deploy (staging). Not needed for local tests.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
