{
  "name": "@getpact/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:assets && tsc --noEmit",
    "build:assets": "node scripts/build-assets.mjs",
    "dev": "pnpm run build:assets && wrangler dev --env local --local-protocol=http --ip 127.0.0.1 --port 19147",
    "deploy": "pnpm run build:assets && wrangler deploy",
    "test": "pnpm run build:assets && vitest run --passWithNoTests --silent",
    "typecheck": "pnpm run build:assets && tsc --noEmit"
  },
  "dependencies": {
    "@getpact/core": "workspace:*",
    "@getpact/logger": "workspace:*",
    "hono": "^4.6.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "wrangler": "^4.0.0"
  }
}
